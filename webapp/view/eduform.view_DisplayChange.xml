	<ObjectPageLayout id="ObjectPageLayout" showTitleInHeaderContent="true" upperCaseAnchorBar="false" >
		
        <headerTitle>
            <ObjectPageDynamicHeaderTitle>
				<actions>
					<m:Button text="Edit" type="Emphasized" press="OnEdit"/>
                    <m:Button text="Submit" type="Emphasized" press="OnNavBack"/>
				</actions>
    			<expandedHeading>
					<m:Title text="Overview of Educational Details" wrapping="true" />
				</expandedHeading>
				<snappedHeading>
					<m:HBox>
						<m:VBox>
							<m:Avatar src="" class="sapUiSmallMarginEnd" />
						</m:VBox>

						<m:VBox>
							<m:Title text="Overview of Educational Details" wrapping="true"/>
							<m:Label design="Bold" text="Educational Details"/>
						</m:VBox>
					</m:HBox>
				</snappedHeading>

				<expandedContent>
					<m:Label design="Bold" text="Educational Details"/>
				</expandedContent>
            </ObjectPageDynamicHeaderTitle>
        </headerTitle>

		<headerContent>
			<m:FlexBox wrap="Wrap" fitContainer="true" >
				<m:Avatar src="" class="sapUiMediumMarginEnd sapUiSmallMarginBottom" displaySize="L"/>

				<m:VBox class="sapUiLargeMarginEnd sapUiSmallMarginBottom" >
				<m:Title text="Employee Basic Details" class="sapUiTinyMarginBottom" />
					<m:HBox class="sapUiTinyMarginBottom" renderType="Bare" >
						<m:Label design="Bold" text="PS ID:" class="sapUiTinyMarginEnd"/>
						<m:Text text="1234567"/>
					</m:HBox>
                    <m:HBox class="sapUiTinyMarginBottom">
						<m:Label design="Bold" text="Email ID:" class="sapUiTinyMarginEnd"/>
						<m:Text text="abc@com"/>
					</m:HBox>
				</m:VBox>

			</m:FlexBox>    
        </headerContent>
		
